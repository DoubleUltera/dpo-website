---
import HeaderLink from './HeaderLink.astro';
import { FACEBOOK_URL } from '../consts';
---

<header>
	<nav>
		<a href="/" class="logo-link">
			<svg class="logo-icon" viewBox="0 0 24 24" width="40" height="40" fill="#1e3a8a">
				<path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V7.3l7-3.11v8.8z"/>
			</svg>
			<span class="logo-text">De Dios Law<span class="logo-tagline">DPO & Data Privacy Services</span></span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/services/dpo-consulting">Services</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="header-actions">
			<a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer" class="header-fb" aria-label="Follow De Dios Law on Facebook">
				<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
				</svg>
			</a>
			<a href="tel:+639196180265" class="header-phone" aria-label="Call +63 919 618 0265">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
				</svg>
				<span>+63 919 618 0265</span>
			</a>
			<a href="/contact" class="header-cta">Contact</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.5em 0;
		text-decoration: none;
	}
	.logo-icon { width: 40px; height: 40px; flex-shrink: 0; }
	.logo-text {
		font-family: 'Spectral', Georgia, serif;
		font-weight: 600;
		font-size: 1.2rem;
		color: var(--color-primary-900);
		letter-spacing: -0.01em;
	}
	.logo-tagline {
		font-family: 'Inter', sans-serif;
		font-weight: 400;
		font-size: 0.95rem;
		color: var(--color-primary-700);
	}
	.logo-tagline::before { content: "|"; margin: 0 0.5rem; font-weight: 300; color: #cbd5e1; }
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.internal-links { display: flex; }
	nav a {
		padding: 1em 0.5em;
		color: var(--color-primary-900);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active { border-bottom-color: var(--color-accent-500); }
	.header-actions { display: flex; align-items: center; gap: 1rem; }
	.header-phone {
		display: inline-flex; align-items: center; gap: 0.4rem;
		color: var(--color-primary-700); font-weight: 600; font-size: 0.95rem;
		white-space: nowrap; border-bottom: none;
	}
	.header-phone svg { width: 18px; height: 18px; }
		.header-fb { display: inline-flex; align-items: center; color: var(--color-primary-700); border-bottom: none; }
		.header-fb:hover { color: var(--color-primary-900); }
		.header-fb svg { width: 22px; height: 22px; }
	.header-cta {
		background: var(--color-primary-600); color: #fff;
		padding: 0 1.1em; min-height: 44px;
		display: inline-flex; align-items: center;
		border-radius: 0.5rem; font-weight: 600; border-bottom: none;
	}
	.header-cta:hover { background: var(--color-primary-700); }
	@media (max-width: 900px) { .header-phone span { display: none; } }
	@media (max-width: 720px) {
		.logo-tagline { display: none; }
		.logo-text { font-size: 1.05rem; }
	}
	@media (max-width: 600px) {
		nav { flex-wrap: wrap; row-gap: 0; }
		.internal-links { order: 3; width: 100%; justify-content: space-between; border-top: 1px solid #eef2f7; }
		nav a { padding: 0.7em 0.4em; }
	}
</style>
