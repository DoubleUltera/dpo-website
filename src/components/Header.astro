---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo-link">
			<svg class="logo-icon" viewBox="0 0 64 64" width="40" height="40">
				<path d="M32 4 L8 14 L8 30 C8 46 32 60 32 60 C32 60 56 46 56 30 L56 14 Z" fill="#0f172a" fill-opacity="0.5" stroke="#0f172a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M22 30 L30 38 L46 22" fill="none" stroke="#f59e0b" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
			<span class="logo-text">De Dios Law<span class="logo-tagline">DPO & Data Privacy Services</span></span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Follow us on Facebook</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.5em 0;
		text-decoration: none;
	}
	.logo-icon {
		width: 40px;
		height: 40px;
		flex-shrink: 0;
	}
	@media (max-width: 640px) {
		.logo-icon {
			width: 32px;
			height: 32px;
		}
	}
	.logo-text {
		font-family: 'Poppins', sans-serif;
		font-weight: 600;
		font-size: 1.125rem;
		color: var(--color-primary-900);
		letter-spacing: -0.01em;
	}
	.logo-tagline {
		font-weight: 400;
		color: var(--color-primary-700);
		letter-spacing: -0.005em;
	}
	.logo-tagline::before {
		content: "|";
		margin: 0 0.5rem;
		font-weight: 300;
		color: #cbd5e1;
		opacity: 0.6;
	}
	@media (max-width: 640px) {
		.logo-tagline {
			display: none;
		}
		.logo-text {
			font-size: 1rem;
		}
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
