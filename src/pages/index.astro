---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = "TÜV Certified Data Protection Officer | DPO Services Region 8 Philippines";
const description = "Atty. Renerio de Dios Jr. - TÜV Certified Data Protection Officer for Region 8, Philippines. Expert data privacy compliance consulting for Leyte, Samar & Biliran. Get your custom quote.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<!-- JSON-LD Schema for Local Business -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": ["Attorney", "ProfessionalService"],
			"name": "Atty. Renerio de Dios Jr. - Data Protection Officer Consulting",
			"description": "TÜV Certified Data Protection Officer providing compliance consulting services in Region 8, Philippines",
			"url": "https://dporegion8.com",
			"areaServed": {
				"@type": "State",
				"name": "Eastern Visayas",
				"address": {
					"@type": "PostalAddress",
					"addressRegion": "Region 8",
					"addressCountry": "PH"
				}
			},
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Tacloban City",
				"addressRegion": "Leyte",
				"addressCountry": "Philippines"
			},
			"priceRange": "Contact for quote",
			"hasCredential": [{
				"@type": "EducationalOccupationalCredential",
				"credentialCategory": "certification",
				"name": "TÜV Certified Data Protection Officer",
				"issuedBy": {
					"@type": "Organization",
					"name": "TÜV Rheinland Philippines"
				},
				"expires": "2029-03-24"
			}],
			"knowsAbout": ["Data Privacy Act 2012", "GDPR", "Privacy Management Program", "Data Protection"],
			"serviceArea": ["Leyte", "Samar", "Biliran", "Eastern Visayas", "Region 8"]
		}
		</script>
	</head>
	<body>
		<Header />

		<!-- Hero Section -->
		<section class="section bg-gradient-to-br from-primary-50 to-white">
			<div class="container">
				<div class="max-w-4xl mx-auto text-center">
					<!-- TÜV Badge -->
					<div class="mb-6 flex justify-center">
						<a href="/tuv-certificate.pdf" target="_blank" class="inline-block" title="View TÜV Certification">
							<div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow">
								<div class="flex items-center gap-4">
									<svg class="w-16 h-16 text-primary-700" fill="currentColor" viewBox="0 0 24 24">
										<path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V7.3l7-3.11v8.8z"/>
									</svg>
									<div class="text-left">
										<div class="text-xs text-neutral-600 uppercase tracking-wide">TÜV Certified</div>
										<div class="text-sm font-semibold text-primary-900">Data Protection Officer</div>
										<div class="text-xs text-neutral-500">Cert #7000532 | Valid until 2029</div>
									</div>
								</div>
							</div>
						</a>
					</div>

					<!-- Headline -->
					<h1 class="text-5xl md:text-6xl font-bold text-primary-900 mb-6">
						<span class="text-primary-600">TÜV Certified</span> Data Protection Officer<br class="hidden md:block"/>
						for Region 8
					</h1>

					<!-- Subheadline -->
					<p class="text-xl md:text-2xl text-neutral-700 mb-8 leading-relaxed">
						Expert compliance consulting for businesses in Leyte, Samar & Biliran.<br/>
						Protect your organization with professional data privacy solutions.
					</p>

					<!-- CTAs -->
					<div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-8">
						<a href="/contact" class="btn-primary">
							<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
							</svg>
							Request Quote
						</a>
						<a href="/services/dpo-consulting" class="btn-secondary">
							Learn More About DPO Services
						</a>
					</div>

					<!-- Trust Indicators -->
					<div class="flex flex-wrap justify-center gap-6 text-sm text-neutral-600">
						<div class="flex items-center gap-2">
							<svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
							</svg>
							<span>Licensed Attorney</span>
						</div>
						<div class="flex items-center gap-2">
							<svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
							</svg>
							<span>Notary Public</span>
						</div>
						<div class="flex items-center gap-2">
							<svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
							</svg>
							<span>Based in Tacloban City</span>
						</div>
						<div class="flex items-center gap-2">
							<svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
							</svg>
							<span>Serving All of Region 8</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Services Overview Section -->
		<section class="section">
			<div class="container">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold text-primary-900 mb-4">
						Comprehensive Data Privacy Solutions
					</h2>
					<p class="text-lg text-neutral-600 max-w-2xl mx-auto">
						Protect your business with expert DPO consulting and legal services tailored for the Philippines
					</p>
				</div>

				<div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
					<!-- DPO Consulting Card -->
					<div class="card">
						<div class="card-body">
							<div class="flex items-start gap-4 mb-4">
								<div class="flex-shrink-0">
									<div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
										<svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
										</svg>
									</div>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-primary-900 mb-2">
										DPO Consulting Services
									</h3>
									<span class="badge-primary text-xs">Primary Service</span>
								</div>
							</div>
							<p class="text-neutral-700 mb-4">
								Ensure full compliance with RA 10173 (Data Privacy Act of 2012) through expert DPO consulting, privacy management programs, and data protection strategies.
							</p>
							<ul class="space-y-2 mb-6 text-sm text-neutral-600">
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Privacy Management Program (PMP) Implementation</span>
								</li>
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Data Privacy Act Compliance Audits</span>
								</li>
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Data Breach Response Planning</span>
								</li>
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>NPC Registration Assistance</span>
								</li>
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Employee Training & Awareness Programs</span>
								</li>
							</ul>
							<a href="/services/dpo-consulting" class="btn-primary w-full text-center">
								Learn More
							</a>
						</div>
					</div>

					<!-- Notarial Services Card -->
					<div class="card">
						<div class="card-body">
							<div class="flex items-start gap-4 mb-4">
								<div class="flex-shrink-0">
									<div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center">
										<svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
										</svg>
									</div>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-primary-900 mb-2">
										Notarial Services
									</h3>
									<span class="badge-accent text-xs">Complementary Service</span>
								</div>
							</div>
							<p class="text-neutral-700 mb-4">
								Professional notarial services to support your business legal requirements, conveniently available alongside DPO consulting.
							</p>
							<ul class="space-y-2 mb-6 text-sm text-neutral-600">
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Affidavits & Sworn Statements</span>
								</li>
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Contracts & Agreements</span>
								</li>
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Special Power of Attorney</span>
								</li>
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Document Authentication</span>
								</li>
								<li class="flex items-start gap-2">
									<svg class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
									</svg>
									<span>Corporate Documentation</span>
								</li>
							</ul>
							<a href="/services/notarial" class="btn-secondary w-full text-center">
								View Services
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Why Choose Us Section -->
		<section class="section bg-neutral-50">
			<div class="container">
				<div class="max-w-4xl mx-auto">
					<h2 class="text-3xl md:text-4xl font-bold text-primary-900 mb-8 text-center">
						Why Choose a TÜV Certified DPO?
					</h2>

					<div class="grid md:grid-cols-3 gap-8 mb-8">
						<div class="text-center">
							<div class="w-16 h-16 bg-primary-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
								1
							</div>
							<h3 class="font-semibold text-lg text-primary-900 mb-2">Internationally Recognized</h3>
							<p class="text-neutral-600 text-sm">
								TÜV certification is globally recognized, ensuring the highest standards of data protection expertise
							</p>
						</div>

						<div class="text-center">
							<div class="w-16 h-16 bg-primary-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
								2
							</div>
							<h3 class="font-semibold text-lg text-primary-900 mb-2">Local Expertise</h3>
							<p class="text-neutral-600 text-sm">
								Deep understanding of Philippine data privacy laws and Region 8 business environment
							</p>
						</div>

						<div class="text-center">
							<div class="w-16 h-16 bg-primary-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
								3
							</div>
							<h3 class="font-semibold text-lg text-primary-900 mb-2">Comprehensive Protection</h3>
							<p class="text-neutral-600 text-sm">
								Legal expertise combined with data protection certification for complete compliance solutions
							</p>
						</div>
					</div>

					<div class="bg-white rounded-xl shadow-md p-8">
						<h3 class="font-semibold text-xl text-primary-900 mb-4">
							Serving All Industries Across Region 8
						</h3>
						<div class="grid md:grid-cols-2 gap-4 text-sm text-neutral-700">
							<div class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
								</svg>
								<span>Healthcare & Medical Facilities</span>
							</div>
							<div class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
								</svg>
								<span>Financial Services & Banks</span>
							</div>
							<div class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
								</svg>
								<span>BPO & Call Centers</span>
							</div>
							<div class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
								</svg>
								<span>Educational Institutions</span>
							</div>
							<div class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
								</svg>
								<span>E-commerce & Retail</span>
							</div>
							<div class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
								</svg>
								<span>Government & Public Sector</span>
							</div>
							<div class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
								</svg>
								<span>HR & Recruitment Agencies</span>
							</div>
							<div class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
								</svg>
								<span>All businesses processing personal data</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="section bg-primary-700 text-white">
			<div class="container">
				<div class="max-w-3xl mx-auto text-center">
					<h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">
						Ready to Protect Your Business?
					</h2>
					<p class="text-xl mb-8 text-primary-100">
						Get a customized data privacy compliance plan tailored to your organization's needs
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="/contact" class="btn bg-white text-primary-700 hover:bg-neutral-100">
							Request Free Consultation
						</a>
						<a href="/about" class="btn-primary">
							Learn About My Credentials
						</a>
