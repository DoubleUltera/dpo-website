---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = "Contact Atty. Renerio de Dios Jr. | TÜV Certified DPO | Tacloban City";
const description = "Contact our TÜV Certified Data Protection Officer for Region 8. Request a free consultation for DPO services or notarial services. Located in Tacloban City, serving all of Eastern Visayas.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<!-- Hero Section -->
		<section class="section bg-gradient-to-br from-primary-50 to-white">
			<div class="container">
				<div class="max-w-3xl mx-auto text-center">
					<h1 class="mb-6">Get in Touch</h1>
					<p class="text-xl text-neutral-700 mb-8">
						Ready to protect your business with expert data privacy consulting? Request a free consultation today.
					</p>
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section class="section">
			<div class="container">
				<div class="max-w-5xl mx-auto">
					<div class="grid md:grid-cols-2 gap-12">
						<!-- Contact Form -->
						<div>
							<h2 class="text-2xl font-semibold text-primary-900 mb-6">Request a Consultation</h2>

							<form id="contact-form" name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" class="space-y-6">
								<input type="hidden" name="form-name" value="contact" />
								<p class="hidden">
									<label>Don't fill this out: <input name="bot-field" /></label>
								</p>
								<!-- Name -->
								<div>
									<label for="name">Full Name *</label>
									<input type="text" id="name" name="name" required />
								</div>

								<!-- Company -->
								<div>
									<label for="company">Company/Organization *</label>
									<input type="text" id="company" name="company" required />
								</div>

								<!-- Email -->
								<div>
									<label for="email">Email Address *</label>
									<input type="email" id="email" name="email" required />
								</div>

								<!-- Phone -->
								<div>
									<label for="phone">Phone Number *</label>
									<input type="tel" id="phone" name="phone" required placeholder="+63 XXX XXX XXXX" />
								</div>

								<!-- Service Interest -->
								<div>
									<label for="service">Service Interest *</label>
									<select id="service" name="service" required>
										<option value="">Select a service</option>
										<option value="DPO Consulting">DPO Consulting</option>
										<option value="Privacy Management Program">Privacy Management Program Implementation</option>
										<option value="Data Privacy Audit">Data Privacy Act Compliance Audit</option>
										<option value="NPC Registration">NPC Registration Assistance</option>
										<option value="Data Breach Response">Data Breach Response Planning</option>
										<option value="Employee Training">Employee Training & Awareness</option>
										<option value="Notarial Services">Notarial Services</option>
										<option value="Both DPO and Notarial">Both DPO and Notarial Services</option>
										<option value="Other">Other / Not Sure</option>
									</select>
								</div>

								<!-- Province -->
								<div>
									<label for="location">Province/City *</label>
									<select id="location" name="location" required>
										<option value="">Select your location</option>
										<optgroup label="Leyte">
											<option value="Tacloban City">Tacloban City</option>
											<option value="Ormoc City">Ormoc City</option>
											<option value="Baybay City">Baybay City</option>
											<option value="Other Leyte">Other Municipality in Leyte</option>
										</optgroup>
										<optgroup label="Samar">
											<option value="Catbalogan City">Catbalogan City</option>
											<option value="Calbayog City">Calbayog City</option>
											<option value="Borongan City">Borongan City</option>
											<option value="Other Samar">Other Municipality in Samar</option>
										</optgroup>
										<optgroup label="Biliran">
											<option value="Naval">Naval, Biliran</option>
											<option value="Other Biliran">Other Municipality in Biliran</option>
										</optgroup>
										<option value="Outside Region 8">Outside Region 8</option>
									</select>
								</div>

								<!-- Message -->
								<div>
									<label for="message">Message *</label>
									<textarea id="message" name="message" required placeholder="Please briefly describe your data privacy compliance needs or questions..."></textarea>
								</div>

								<!-- Consent -->
								<div>
									<label class="flex items-start gap-3">
										<input type="checkbox" id="consent" name="consent" required class="mt-1" style="min-height: auto; width: auto;" />
										<span class="text-sm text-neutral-700">
											I agree to be contacted regarding my inquiry and understand that my personal information will be processed in accordance with the Data Privacy Act of 2012. *
										</span>
									</label>
								</div>

								<!-- Submit Button -->
								<button type="submit" class="btn-primary w-full">
									<span id="submit-text">Send Message</span>
									<span id="submit-loading" class="hidden">Sending...</span>
								</button>

								<!-- Success Message -->
								<div id="success-message" class="hidden bg-primary-50 border border-primary-200 text-primary-800 px-4 py-3 rounded-lg">
									<p class="font-semibold">Thank you for your inquiry!</p>
									<p class="text-sm mt-1">Your message has been sent successfully. I will respond within 24-48 business hours.</p>
								</div>

								<!-- Error Message -->
								<div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
									<p class="font-semibold">Oops! Something went wrong.</p>
									<p class="text-sm mt-1">Please try again or contact me directly via email or phone below.</p>
								</div>
							</form>
						</div>

						<!-- Contact Information -->
						<div>
							<h2 class="text-2xl font-semibold text-primary-900 mb-6">Contact Information</h2>

							<div class="space-y-6">
								<!-- Location -->
								<div class="flex items-start gap-4">
									<div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
										<svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-primary-900 mb-1">Office Location</h3>
										<p class="text-neutral-700">
											De Dios Law<br/>
											Unit 2, Pacer Apartments<br/>
											Gurami Street, V&G Subdivision<br/>
											Barangay 109-A, Tacloban City<br/>
											Leyte 6500
										</p>
									</div>
								</div>

								<!-- Email -->
								<div class="flex items-start gap-4">
									<div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
										<svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-primary-900 mb-1">Email</h3>
										<p class="text-neutral-700">
											<a href="mailto:dpo@dedioslaw.ph" class="text-primary-600 hover:text-primary-700">
												dpo@dedioslaw.ph
											</a>
											<br/>
											<span class="text-sm text-neutral-600">We respond within 24-48 hours</span>
										</p>
									</div>
								</div>

								<!-- Phone -->
								<div class="flex items-start gap-4">
									<div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
										<svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-primary-900 mb-1">Phone</h3>
										<p class="text-neutral-700">
											<a href="tel:+639XXXXXXXXX" class="text-primary-600 hover:text-primary-700">
												+63 9XX XXX XXXX
											</a>
											<br/>
											<span class="text-sm text-neutral-600">Monday - Friday, 9:00 AM - 5:00 PM</span>
										</p>
									</div>
								</div>

								<!-- Business Hours -->
								<div class="bg-neutral-50 p-6 rounded-lg">
									<h3 class="font-semibold text-primary-900 mb-3">Business Hours</h3>
									<div class="space-y-2 text-sm text-neutral-700">
										<div class="flex justify-between">
											<span>Monday - Friday:</span>
											<span class="font-medium">9:00 AM - 5:00 PM</span>
										</div>
										<div class="flex justify-between">
											<span>Saturday:</span>
											<span class="font-medium">By Appointment</span>
										</div>
										<div class="flex justify-between">
											<span>Sunday:</span>
											<span class="font-medium">Closed</span>
										</div>
									</div>
									<p class="text-xs text-neutral-600 mt-4">
										For urgent data breach incidents, emergency consultations may be available outside regular hours.
									</p>
								</div>

								<!-- Certifications -->
								<div class="bg-primary-50 p-6 rounded-lg">
									<h3 class="font-semibold text-primary-900 mb-3">Credentials</h3>
									<ul class="space-y-2 text-sm text-neutral-700">
										<li class="flex items-start gap-2">
											<svg class="w-5 h-5 text-accent-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
											</svg>
											<span>TÜV Certified Data Protection Officer</span>
										</li>
										<li class="flex items-start gap-2">
											<svg class="w-5 h-5 text-accent-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
											</svg>
											<span>Licensed Attorney (Philippine Bar)</span>
										</li>
										<li class="flex items-start gap-2">
											<svg class="w-5 h-5 text-accent-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
											</svg>
											<span>Commissioned Notary Public</span>
										</li>
									</ul>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Map Section (Placeholder) -->
		<section class="section bg-neutral-50">
			<div class="container">
				<div class="max-w-5xl mx-auto">
					<h2 class="text-center mb-8">Serving All of Region 8 (Eastern Visayas)</h2>
					<p class="text-center text-neutral-700 mb-8">
						Based in Tacloban City, providing DPO consulting services across Leyte, Samar, and Biliran provinces
					</p>
					<div class="rounded-lg overflow-hidden h-64">
						<iframe
							src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3916.7919999999997!2d124.9951109!3d11.2062239!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x33087700268f87b7%3A0xb0848637a6603d5b!2sPacer%20Apartment!5e0!3m2!1sen!2sph!4v1234567890123!5m2!1sen!2sph"
							width="100%"
							height="100%"
							style="border:0;"
							allowfullscreen=""
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade">
						</iframe>
					</div>
				</div>
			</div>
		</section>

		<Footer />

		<!-- Netlify Form Handler -->
		<script>
			const contactForm = document.getElementById('contact-form');
			const submitButton = contactForm.querySelector('button[type="submit"]');
			const submitText = document.getElementById('submit-text');
			const submitLoading = document.getElementById('submit-loading');
			const successMessage = document.getElementById('success-message');
			const errorMessage = document.getElementById('error-message');

			contactForm.addEventListener('submit', async function(event) {
				event.preventDefault();

				// Hide previous messages
				successMessage.classList.add('hidden');
				errorMessage.classList.add('hidden');

				// Show loading state
				submitButton.disabled = true;
				submitText.classList.add('hidden');
				submitLoading.classList.remove('hidden');

				try {
					const formData = new FormData(contactForm);

					const response = await fetch('/', {
						method: 'POST',
						headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
						body: new URLSearchParams(formData).toString()
					});

					// Netlify returns 200 on success, but also accept redirects
					if (response.ok || response.status === 303 || response.status === 302) {
						// Show success message
						successMessage.classList.remove('hidden');
						// Reset form
						contactForm.reset();
						// Scroll to success message
						successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
					} else {
						console.error('Form error:', response.status, response.statusText);
						throw new Error('Form submission failed');
					}
				} catch (error) {
					console.error('Form submission error:', error);
					// Show error message
					errorMessage.classList.remove('hidden');
					// Scroll to error message
					errorMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
				} finally {
					// Reset button state
					submitButton.disabled = false;
					submitText.classList.remove('hidden');
					submitLoading.classList.add('hidden');
				}
			});
		</script>
	</body>
</html>
