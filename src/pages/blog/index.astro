---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const title = "Data Privacy & Compliance Blog | Expert Insights from Region 8";
const description = "Stay informed about Philippine data privacy laws, DPA compliance tips, and NPC updates. Expert insights from a TÜV Certified Data Protection Officer serving Eastern Visayas.";

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="container py-16">
			<!-- Blog Header -->
			<section class="text-center mb-16">
				<h1 class="text-4xl md:text-5xl font-bold text-primary-900 mb-4">
					Data Privacy & Compliance Blog
				</h1>
				<p class="text-xl text-neutral-700 max-w-3xl mx-auto">
					Practical insights, compliance guides, and legal updates on Philippine data privacy laws from a TÜV Certified DPO serving Region 8.
				</p>
			</section>

			<!-- Blog Posts Grid -->
			<section class="max-w-6xl mx-auto">
				<style>
					.gradient-card {
						background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
						height: 200px;
						display: flex;
						align-items: center;
						justify-content: center;
						padding: 2rem;
						text-align: center;
						position: relative;
						overflow: hidden;
					}

					.gradient-card::before {
						content: '';
						position: absolute;
						top: 0;
						left: 0;
						right: 0;
						bottom: 0;
						background: linear-gradient(45deg, rgba(245, 158, 11, 0.1) 0%, transparent 100%);
						opacity: 0;
						transition: opacity 0.3s;
					}

					.card.group:hover .gradient-card::before {
						opacity: 1;
					}

					.gradient-card h3 {
						color: white;
						font-size: 1.25rem;
						font-weight: 600;
						line-height: 1.3;
						margin: 0;
						position: relative;
						z-index: 1;
					}

					.gradient-card .category-badge {
						position: absolute;
						top: 1rem;
						left: 1rem;
						background-color: rgba(245, 158, 11, 0.9);
						color: white;
						padding: 0.25rem 0.75rem;
						border-radius: 9999px;
						font-size: 0.75rem;
						font-weight: 600;
						text-transform: uppercase;
						letter-spacing: 0.05em;
					}

					.line-clamp-3 {
						display: -webkit-box;
						-webkit-line-clamp: 3;
						-webkit-box-orient: vertical;
						overflow: hidden;
					}
				</style>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{posts.map((post) => (
						<article class="card group">
							<a href={`/blog/${post.id}/`} class="block">
								{post.data.heroImage ? (
									<div class="overflow-hidden rounded-t-xl">
										<Image
											width={720}
											height={360}
											src={post.data.heroImage}
											alt={post.data.title}
											class="w-full h-48 object-cover transition-transform duration-300 group-hover:scale-105"
										/>
									</div>
								) : (
									<div class="gradient-card rounded-t-xl">
										{post.data.category && (
											<span class="category-badge">
												{post.data.category}
											</span>
										)}
										<h3>{post.data.title}</h3>
									</div>
								)}
								<div class="card-body">
									{!post.data.heroImage && post.data.category && (
										<span class="badge-primary text-xs mb-2 inline-block">
											{post.data.category}
										</span>
									)}
									{post.data.heroImage && (
										<>
											{post.data.category && (
												<span class="badge-primary text-xs mb-2 inline-block">
													{post.data.category}
												</span>
											)}
											<h2 class="text-xl font-semibold text-primary-900 mb-2 group-hover:text-primary-600 transition-colors">
												{post.data.title}
											</h2>
										</>
									)}
									<p class="text-neutral-600 text-sm mb-4 line-clamp-3">
										{post.data.description}
									</p>
									<div class="flex items-center justify-between text-sm text-neutral-500">
										<FormattedDate date={post.data.pubDate} />
										<span class="text-primary-600 group-hover:underline">
											Read more →
										</span>
									</div>
								</div>
							</a>
						</article>
					))}
				</div>
			</section>

			<!-- CTA Section -->
			<section class="mt-16 text-center">
				<div class="bg-primary-700 text-white rounded-xl p-8 max-w-4xl mx-auto">
					<h2 class="text-3xl font-bold mb-4" style="color: white;">
						Need Expert DPO Consulting?
					</h2>
					<p class="text-xl mb-6 text-primary-100">
						Get personalized data privacy compliance guidance from a TÜV Certified Data Protection Officer
					</p>
					<a href="/contact" class="btn bg-white text-primary-700 hover:bg-neutral-100">
						Request Free Consultation
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
